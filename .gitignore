.idea/
*.iml
*.ipr
*.iws
.vscode/
.classpath
.project
.settings/
.metadata/
.recommenders/

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini

# --- Compiled classes (defensive; build/ above catches most) ---
*.class
target/